#!/bin/sh
#
# Pre-commit hook for mds
# Runs formatting check and clippy before allowing commit.

set -e

echo "pre-commit: checking Rust formatting..."
cd crates
cargo fmt --check 2>&1 || {
    echo ""
    echo "error: Rust formatting check failed."
    echo "hint: Run 'cargo fmt' in crates/ to fix formatting."
    exit 1
}

echo "pre-commit: running clippy..."
cargo clippy -- -D warnings 2>&1 || {
    echo ""
    echo "error: clippy found warnings."
    echo "hint: Fix the warnings reported above."
    exit 1
}

echo "pre-commit: all checks passed."
