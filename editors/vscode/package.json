{
  "name": "mds",
  "displayName": "mds - Markdown Source",
  "description": "Language support for mds (Markdown Source) implementation files",
  "version": "0.2.1-alpha",
  "publisher": "owo-x-project",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/owo-x-project/owox-mds",
    "directory": "editors/vscode"
  },
  "homepage": "https://github.com/owo-x-project/owox-mds",
  "bugs": {
    "url": "https://github.com/owo-x-project/owox-mds/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets"
  ],
  "activationEvents": [
    "workspaceContains:**/mds.config.toml",
    "onLanguage:mds-markdown",
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mds-markdown",
        "aliases": [
          "mds Markdown"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mds-markdown",
        "scopeName": "text.html.markdown.mds",
        "path": "./syntaxes/mds-markdown.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "mds-markdown",
        "path": "./snippets/mds.json"
      }
    ],
    "configuration": {
      "title": "mds",
      "properties": {
        "mds.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to the mds-lsp binary. If empty, uses the binary from PATH."
        },
        "mds.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the mds language server."
        },
        "mds.lsp.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "description": "Log level for the mds language server."
        },
        "mds.lsp.additionalLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional language file extensions to activate (e.g., '.go.md', '.java.md')."
        }
      }
    },
    "commands": [
      {
        "command": "mds.openPreview",
        "title": "mds: Open Markdown Preview",
        "category": "mds"
      },
      {
        "command": "mds.openPreviewToSide",
        "title": "mds: Open Markdown Preview to the Side",
        "category": "mds"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "mds.openPreviewToSide",
          "when": "resourceExtname == .md && editorLangId == mds-markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "mds.openPreview",
          "when": "resourceExtname == .md && editorLangId == mds-markdown",
          "group": "navigation"
        },
        {
          "command": "mds.openPreviewToSide",
          "when": "resourceExtname == .md && editorLangId == mds-markdown",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "mds.openPreview",
          "when": "editorLangId == mds-markdown"
        },
        {
          "command": "mds.openPreviewToSide",
          "when": "editorLangId == mds-markdown"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "package:build": "../../.github/script/package-vscode.sh --pre-release",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
