{
  "mds: New Implementation Document": {
    "prefix": "mds-doc",
    "body": [
      "## Purpose",
      "",
      "${1:Describe the module purpose}",
      "",
      "## Contract",
      "",
      "${2:Define the public contract}",
      "",
      "## Exports",
      "",
      "| Name | Visibility | Summary |",
      "| --- | --- | --- |",
      "| ${3:symbolName} | public | ${4:Describe the public definition.} |",
      "",
      "##### ${3:symbolName}",
      "",
      "${5:Describe the shared definition and who should reference it.}",
      "",
      "## Imports",
      "",
      "| From | Target | Symbols | Via | Summary | Reference |",
      "| --- | --- | --- | --- | --- | --- |",
      "| ${6:builtin} | ${7:target} | ${8:Name} | - | ${9:description} | - |",
      "",
      "## Types",
      "",
      "```${10:typescript}",
      "${11:// type definitions}",
      "```",
      "",
      "## Source",
      "",
      "```${12:typescript}",
      "${13:// implementation}",
      "```",
      "",
      "## Cases",
      "",
      "${14:Describe use cases}"
    ],
    "description": "Full mds implementation document template"
  },
  "mds: Imports Table": {
    "prefix": "mds-imports",
    "body": [
      "## Imports",
      "",
      "| From | Target | Symbols | Via | Summary | Reference |",
      "| --- | --- | --- | --- | --- | --- |",
      "| ${1|builtin,external,package,workspace,internal|} | ${2:target} | ${3:Name} | ${4:-} | ${5:description} | ${6:-} |"
    ],
    "description": "Imports table with header"
  },
  "mds: Imports Row": {
    "prefix": "mds-import-row",
    "body": [
      "| ${1|builtin,external,package,workspace,internal|} | ${2:target} | ${3:Name} | ${4:-} | ${5:description} | ${6:-} |"
    ],
    "description": "Single Imports table row"
  },
  "mds: Section": {
    "prefix": "mds-section",
    "body": [
      "## ${1|Purpose,Contract,Exports,Imports,Types,Source,Cases,Test,Covers|}",
      "",
      "${2:content}",
      ""
    ],
    "description": "mds section heading"
  },
  "mds: Code Section": {
    "prefix": "mds-code-section",
    "body": [
      "## ${1|Types,Source,Test|}",
      "",
      "```${6:typescript}",
      "${7:// code}",
      "```"
    ],
    "description": "mds code section with Uses table and code block"
  },
  "mds: Code Block": {
    "prefix": "mds-code",
    "body": [
      "```${1|typescript,python,rust|}",
      "${2:// code}",
      "```"
    ],
    "description": "Code block with language label"
  },
  "mds.config.toml: Basic Config": {
    "prefix": "mds-config",
    "body": [
      "[package]",
      "enabled = true",
      "",
      "[roots]",
      "markdown = \"src-md\"",
      "source = \"src\"",
      "types = \"src\"",
      "test = \"tests\"",
      "",
      "[adapters.${1|ts,py,rs|}]",
      "enabled = true"
    ],
    "description": "Basic mds.config.toml configuration"
  },
  "mds.config.toml: Full Config": {
    "prefix": "mds-config-full",
    "body": [
      "[package]",
      "enabled = true",
      "allow_raw_source = false",
      "",
      "[roots]",
      "markdown = \"src-md\"",
      "source = \"src\"",
      "types = \"src\"",
      "test = \"tests\"",
      "excludes = []",
      "",
      "[adapters.ts]",
      "enabled = ${1:true}",
      "",
      "[adapters.py]",
      "enabled = ${2:true}",
      "",
      "[adapters.rs]",
      "enabled = ${3:true}",
      "",
      "[quality.ts]",
      "lint = \"${4:eslint}\"",
      "test = \"${5:vitest run}\"",
      "",
      "[labels]",
      "# purpose = \"目的\"",
      "# contract = \"契約\""
    ],
    "description": "Full mds.config.toml with all sections"
  }
}
