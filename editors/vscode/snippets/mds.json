{
  "mds: New Source Document": {
    "prefix": "mds-doc",
    "body": [
      "## Purpose",
      "",
      "${1:Describe the module purpose}",
      "",
      "## Contract",
      "",
      "${2:Define behavior, constraints, and boundaries}",
      "",
      "## API",
      "",
      "${3:Describe the public API in prose. Keep import/export details in the source block.}",
      "",
      "## Source",
      "",
      "```${4:typescript}",
      "${5:// implementation}",
      "```",
      "",
      "## Cases",
      "",
      "- ${6:Describe expected behavior}"
    ],
    "description": "Tableless authoring-v2 source document"
  },
  "mds: New Test Document": {
    "prefix": "mds-test-doc",
    "body": [
      "## Purpose",
      "",
      "${1:Describe the verification goal}",
      "",
      "## Covers",
      "",
      "- ${2:module.id}",
      "",
      "## Cases",
      "",
      "- ${3:Describe the test case}",
      "",
      "## Test",
      "",
      "```${4:typescript}",
      "${5:// test code}",
      "```"
    ],
    "description": "Tableless authoring-v2 test document"
  },
  "mds: New Spec Document": {
    "prefix": "mds-spec-doc",
    "body": [
      "## Purpose",
      "",
      "${1:Describe the feature purpose}",
      "",
      "## Contract",
      "",
      "${2:Define behavior, constraints, and boundaries}",
      "",
      "## API",
      "",
      "${3:Describe the public API in prose.}",
      "",
      "## Cases",
      "",
      "- ${4:Describe expected behavior}"
    ],
    "description": "Tableless source spec without generated code"
  },
  "mds: Section": {
    "prefix": "mds-section",
    "body": [
      "## ${1|Purpose,Contract,API,Source,Cases,Covers,Test|}",
      "",
      "${2:content}",
      ""
    ],
    "description": "mds section heading"
  },
  "mds: Code Section": {
    "prefix": "mds-code-section",
    "body": [
      "## ${1|Source,Test|}",
      "",
      "```${2:typescript}",
      "${3:// code}",
      "```"
    ],
    "description": "mds source/test code section"
  },
  "mds: Code Block": {
    "prefix": "mds-code",
    "body": [
      "```${1|typescript,python,rust|}",
      "${2:// code}",
      "```"
    ],
    "description": "Code block with language label"
  },
  "mds.config.toml: Basic Config": {
    "prefix": "mds-config",
    "body": [
      "[package]",
      "enabled = true",
      "allow_raw_source = false",
      "",
      "[roots]",
      "source_md = \".mds/source\"",
      "test_md = \".mds/test\"",
      "source_out = \"src\"",
      "test_out = \"tests\"",
      "",
      "[output]",
      "source = \"{source_out}/{module}.{ext}\"",
      "test = \"{test_out}/{module}.test.{ext}\"",
      "",
      "[quality.${1|ts,py,rs|}]",
      "linter = \"${2:}\"",
      "fixer = \"${3:}\"",
      "test_runner = \"${4:}\"",
      "required = []",
      "optional = []"
    ],
    "description": "Basic authoring-v2 mds.config.toml configuration"
  },
  "mds.config.toml: Full Config": {
    "prefix": "mds-config-full",
    "body": [
      "[package]",
      "enabled = true",
      "allow_raw_source = false",
      "",
      "[roots]",
      "source_md = \".mds/source\"",
      "test_md = \".mds/test\"",
      "source_out = \"src\"",
      "test_out = \"tests\"",
      "",
      "[output]",
      "source = \"{source_out}/{module}.{ext}\"",
      "test = \"{test_out}/{module}.test.{ext}\"",
      "",
      "[[output.override]]",
      "match = \"${1:build}\"",
      "kind = \"${2|source,test|}\"",
      "path = \"${3:build.rs}\"",
      "",
      "[quality.ts]",
      "linter = \"${4:eslint}\"",
      "fixer = \"${5:prettier --write}\"",
      "test_runner = \"${6:vitest run}\"",
      "required = []",
      "optional = []",
      "",
      "[labels]",
      "# purpose = \"目的\"",
      "# contract = \"契約\""
    ],
    "description": "Full authoring-v2 mds.config.toml with output override"
  }
}