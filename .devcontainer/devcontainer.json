{
  "name": "mds-dev",
  "dockerComposeFile": "compose.yml",
  "service": "dev",
  "runServices": [
    "dev"
  ],
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "updateRemoteUserUID": true,
  "shutdownAction": "stopCompose",
  "overrideCommand": false,
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/usr/local/cargo/bin:/home/vscode/.npm-global/bin:/home/vscode/.local/bin:/usr/local/bin"
  },
  "customizations": {
    "vscode": {
      "extensions": [],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.eol": "\n"
      }
    }
  }
}
